{
  "name": "Fresh",
  "version": "0.0.1",
  "description": "Document database for ESP32 devices with RAM-first writes and async LittleFS persistence.",
  "keywords": [
    "esp32",
    "database",
    "littlefs",
    "arduinojson",
    "storage"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ZekStack/fresh.git"
  },
  "authors": [
    {
      "name": "zekageri",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": "espressif32",
  "dependencies": {
    "bblanchon/ArduinoJson": ">=7.0.0"
  },
  "build": {
    "srcDir": "src",
    "includeDir": "src",
    "flags": [
      "-std=gnu++20"
    ]
  }
}
